# URL pública canônica do site (sem barra final). Na Vercel (Production/Preview) é obrigatória
# para URLs absolutas em sitemap.xml, robots.txt e metadados (Open Graph, JSON-LD base, etc.).
# Ex.: https://<projeto>.vercel.app ou domínio customizado.
# Desenvolvimento local: use http://localhost:3000 no seu .env.local.
NEXT_PUBLIC_SITE_URL=

# PostHog — analytics client-side
# Obtenha sua chave em: https://app.posthog.com/project/settings
NEXT_PUBLIC_POSTHOG_KEY=phc_<sua_project_api_key>
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# PostHog — analytics server-side
# Use uma Project API Key, não uma personal API key
POSTHOG_PROJECT_API_KEY=
POSTHOG_HOST=https://us.i.posthog.com
